<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Customer Feedback</title>

<!-- Google Font -->
<link href="https://fonts.googleapis.com/css2?family=Domine:wght@400;600&display=swap" rel="stylesheet">

<style>
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family: 'Domine', serif;
}

body {
  background: #e9e9e9;
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
}

/* CONTAINER */
.feedback-container {
  width: 900px;
  background: #f5f5f5;
  padding: 30px;
  border-radius: 10px;
}

/* HEADER */
.feedback-title {
  text-align: center;
  color: #1b4d0f;
  margin-bottom: 20px;
}

.feedback-title h1 {
  font-size: 36px;
}

.feedback-title p {
  font-size: 14px;
}

/* BOX */
.feedback-box {
  border: 2px solid #1b4d0f;
  border-radius: 15px;
  padding: 30px;
}

/* LABELS */
.label {
  color: #1b4d0f;
  font-size: 22px;
  margin-bottom: 10px;
  display: block;
}

/* STARS */
.stars {
  font-size: 26px;
  color: #1b4d0f;
  margin-bottom: 20px;
  cursor: pointer;
}
.stars span {
  font-size: 30px;
  cursor: pointer;
  color: #ccc; /* default gray */
  transition: 0.2s;
}

/* kapag selected */
.stars .active {
  color: gold;
}

/* hover preview */
.stars span:hover,
.stars span:hover ~ span {
  color: #ccc;
}
/* TEXTAREA */
textarea {
  width: 100%;
  height: 150px;
  border: 2px solid #1b4d0f;
  border-radius: 15px;
  padding: 15px;
  resize: none;
  outline: none;
  margin-bottom: 20px;
}

/* YES/NO BUTTONS */
.recommend {
  margin-top: 10px;
}

.btn-group {
  display: flex;
  gap: 20px;
  margin-top: 10px;
}

.option-btn {
  flex: 1;
  padding: 15px;
  border: 2px solid #1b4d0f;
  border-radius: 15px;
  background: transparent;
  color: #1b4d0f;
  font-size: 18px;
  cursor: pointer;
  transition: 0.3s;
}

.option-btn:hover {
  background: #1b4d0f;
  color: white;
}

/* SEND BUTTON */
.send-btn {
  width: 100%;
  margin-top: 20px;
  padding: 15px;
  background: #1b4d0f;
  color: white;
  border: none;
  border-radius: 15px;
  font-size: 16px;
  cursor: pointer;
  transition: 0.3s;
}

.send-btn:hover {
  opacity: 0.9;
}
</style>
</head>

<body>

<div class="feedback-container">

  <div class="feedback-title">
    <h1>Customer Feedback</h1>
    <p>Help us improve your experience</p>
  </div>

  <div class="feedback-box">

    <label class="label">Rate your Experince</label>
<div class="stars" id="starRating">
  <span data-value="1">☆</span>
  <span data-value="2">☆</span>
  <span data-value="3">☆</span>
  <span data-value="4">☆</span>
  <span data-value="5">☆</span>
</div>

<input type="hidden" id="ratingValue">
    <label class="label">Your Comments</label>
    <textarea></textarea>

    <div class="recommend">
      <label class="label">Would you recommend us ?</label>

      <div class="btn-group">
        <button class="option-btn">YES</button>
        <button class="option-btn">NO</button>
      </div>
    </div>

  </div>

  <button class="send-btn">SEND</button>

</div>

</body>
</html>
<script>
const stars = document.querySelectorAll("#starRating span");
const ratingValue = document.getElementById("ratingValue");

stars.forEach((star, index) => {

  star.addEventListener("click", () => {
    let value = star.getAttribute("data-value");
    ratingValue.value = value;

    stars.forEach((s, i) => {
      s.classList.toggle("active", i < value);
    });
  });

});
</script>
